{
	"info": {
		"name": "Smart Bank API",
		"description": "Complete API collection for Smart Bank Management System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "customerToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "adminToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "accountNumber",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"customer@bank.com\",\n  \"password\": \"Customer@123\",\n  \"fullName\": \"John Doe\",\n  \"phone\": \"9876543210\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						}
					}
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"customer@bank.com\",\n  \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"verify-otp"
							]
						}
					}
				},
				{
					"name": "Login (Customer)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set(\"customerToken\", jsonData.data.token);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"customer@bank.com\",\n  \"password\": \"Customer@123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					}
				},
				{
					"name": "Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set(\"adminToken\", jsonData.data.token);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@bank.com\",\n  \"password\": \"Admin@123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "Accounts",
			"item": [
				{
					"name": "Create Account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set(\"accountNumber\", jsonData.data.accountNumber);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"SAVINGS\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/accounts",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"accounts"
							]
						}
					}
				},
				{
					"name": "Get My Accounts",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/accounts",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"accounts"
							]
						}
					}
				},
				{
					"name": "Get Account by Number",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/accounts/{{accountNumber}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"accounts",
								"{{accountNumber}}"
							]
						}
					}
				}
			]
		},
		{
			"name": "Transfers",
			"item": [
				{
					"name": "Transfer Funds",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fromAccountNumber\": \"ACC123\",\n  \"toAccountNumber\": \"ACC456\",\n  \"amount\": 5000.00,\n  \"description\": \"Payment for services\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/transfer",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"transfer"
							]
						}
					}
				}
			]
		},
		{
			"name": "Transactions",
			"item": [
				{
					"name": "Get Account Transactions",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/transactions/{{accountNumber}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"transactions",
								"{{accountNumber}}"
							]
						}
					}
				},
				{
					"name": "Get Recent Transactions",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/transactions/{{accountNumber}}/recent",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"transactions",
								"{{accountNumber}}",
								"recent"
							]
						}
					}
				}
			]
		},
		{
			"name": "Loans (Customer)",
			"item": [
				{
					"name": "Apply for Loan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 50000.00,\n  \"tenureMonths\": 12,\n  \"purpose\": \"Home renovation project\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/loans",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"loans"
							]
						}
					}
				},
				{
					"name": "Get My Loans",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/loans",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"loans"
							]
						}
					}
				},
				{
					"name": "Get Loan by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{customerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/loans/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"loans",
								"1"
							]
						}
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Get Pending Loans",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/admin/loans/pending",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"loans",
								"pending"
							]
						}
					}
				},
				{
					"name": "Get Loans by Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/admin/loans?status=APPROVED",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"loans"
							],
							"query": [
								{
									"key": "status",
									"value": "APPROVED"
								}
							]
						}
					}
				},
				{
					"name": "Approve Loan",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"approved\": true,\n  \"remarks\": \"Approved based on good credit score\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/admin/loans/1/approve",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"loans",
								"1",
								"approve"
							]
						}
					}
				},
				{
					"name": "Reject Loan",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"approved\": false,\n  \"remarks\": \"Insufficient credit score\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/admin/loans/1/approve",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"loans",
								"1",
								"approve"
							]
						}
					}
				},
				{
					"name": "Mark Under Review",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/admin/loans/1/review",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"loans",
								"1",
								"review"
							]
						}
					}
				}
			]
		}
	]
}